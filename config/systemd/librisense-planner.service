[Unit]
Description=LibriSense planner (library/problem -> Fast Downward -> library/plan)
After=network-online.target mosquitto.service
Wants=network-online.target
StartLimitIntervalSec=60
StartLimitBurst=10

[Service]
Type=simple
Environment=PYTHONUNBUFFERED=1
User=librisense
WorkingDirectory=/home/librisense/librisense
ExecStart=/home/librisense/librisense/.venv/bin/python modules/planner/planner_service.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
