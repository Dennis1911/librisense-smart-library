[Unit]
Description=LibriSense local LCD status display (library/state -> Grove LCD)
After=network-online.target librisense-sensors.service
Wants=network-online.target
StartLimitIntervalSec=60
StartLimitBurst=10

[Service]
Type=simple
Environment=PYTHONUNBUFFERED=1
User=librisense
WorkingDirectory=/home/librisense/librisense
ExecStart=/home/librisense/librisense/.venv/bin/python modules/iot/lcd_display.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
