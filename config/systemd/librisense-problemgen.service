[Unit]
Description=LibriSense problem generator (library/state -> library/problem)
After=network-online.target mosquitto.service
Wants=network-online.target
StartLimitIntervalSec=60
StartLimitBurst=10

[Service]
Type=simple
Environment=PYTHONUNBUFFERED=1
User=librisense
WorkingDirectory=/home/librisense/librisense
ExecStart=/home/librisense/librisense/.venv/bin/python modules/problem_generator/generator.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
