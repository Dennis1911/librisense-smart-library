[Unit]
Description=LibriSense weather software-sensor (Open-Meteo -> MQTT)
After=network-online.target mosquitto.service
Wants=network-online.target
StartLimitIntervalSec=60
StartLimitBurst=10

[Service]
Type=simple
Environment=PYTHONUNBUFFERED=1
User=librisense
WorkingDirectory=/home/librisense/librisense
ExecStart=/home/librisense/librisense/.venv/bin/python modules/iot/weather_sensor.py
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
