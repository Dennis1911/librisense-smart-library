[Unit]
Description=LibriSense actuator service (library/actions -> Plugwise relay)
After=network-online.target librisense-sensors.service
Wants=network-online.target
StartLimitIntervalSec=120
StartLimitBurst=5

[Service]
Type=simple
Environment=PYTHONUNBUFFERED=1
User=librisense
WorkingDirectory=/home/librisense/librisense
ExecStart=/home/librisense/librisense/.venv/bin/python modules/iot/actuator_service.py
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
